# ====================
# Node / Vue
# ====================
node_modules/         # Node dependencies
dist/                 # Vue build output
.vitest/              # Vitest internal cache
*.snap                # Snapshot files from component tests

# ====================
# Environment / Config
# ====================
.env                  # Local environment variables
*.local               # Optional local env overrides

# ====================
# Backend / PHP
# ====================
*.sqlite              # Local SQLite DB
logs/                 # Any backend log folders
*.log                 # Log files

# ====================
# Editor / OS
# ====================
.vscode/              # VSCode settings
.idea/                # PHPStorm / IntelliJ settings
.DS_Store             # MacOS file system metadata
Thumbs.db             # Windows file system metadata

# ====================
# Temp / Cache
# ====================
.cache/
.temp/
.tmp/